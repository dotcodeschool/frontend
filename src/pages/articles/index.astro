---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/shared/components/Navbar.astro'
import ArticlesPage from '@/features/articles/components/ArticlesPage'
import { getArticles } from '@/features/articles/lib/loader'
import Footer from '@/shared/components/Footer.astro'

const articles = getArticles()
---

<BaseLayout title="Articles — Dot Code School">
  <Navbar />
  <main class="max-w-5xl mx-auto px-6 py-10">
    <ArticlesPage articles={articles} client:load />
  </main>
  <Footer />
</BaseLayout>
