---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/shared/components/Navbar.astro'
import { getArticles, getArticle } from '@/features/articles/lib/loader'
import MdxRenderer from '@/shared/components/MdxRenderer'

export function getStaticPaths() {
  return getArticles().map(a => ({ params: { slug: a.slug } }))
}

const { slug } = Astro.params
const article = await getArticle(slug!)

if (!article) return Astro.redirect('/404')
---

<BaseLayout title={`${article.title} — Dot Code School`}>
  <Navbar />
  <main class="max-w-3xl mx-auto px-4 py-8">
    <a href="/articles" class="text-accent text-sm mb-4 block no-underline">← Articles</a>
    <h1 class="font-heading text-3xl font-bold mb-2">{article.title}</h1>
    <p class="text-content-muted text-sm mb-8">{article.date} · {article.author}</p>
    <div class="prose prose-invert max-w-none text-content-primary
                 prose-headings:font-heading prose-headings:text-content-primary">
      <MdxRenderer code={article.code} client:load />
    </div>
  </main>
</BaseLayout>
