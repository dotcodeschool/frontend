---
export const prerender = false

import { getSession } from '@/features/auth/lib/session'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Footer from '@/shared/components/Footer.astro'
import Navbar from '@/shared/components/Navbar.astro'

const session = await getSession(Astro.request)
const redirectTo = Astro.url.searchParams.get('redirect') ?? '/courses'

if (session) {
  return Astro.redirect(redirectTo)
}
---

<BaseLayout title="Sign In — Dot Code School">
  <Navbar />
  <main class="flex-1 flex items-center justify-center px-4 py-16">
    <div class="max-w-sm w-full text-center">
      <!-- Logo -->
      <div class="mb-8">
        <span class="font-mono text-accent font-bold text-2xl">&lt;/&gt;</span>
        <h1 class="font-heading text-2xl font-bold mt-3">Sign in to Dot Code School</h1>
        <p class="text-content-muted text-sm mt-2">Sign in to sync your progress across devices and get your own GitHub repos for courses.</p>
      </div>

      <!-- Sign in button -->
      <button
        id="github-signin"
        class="flex items-center justify-center gap-2.5 w-full bg-elevated border border-border text-content-primary text-sm font-medium px-6 py-3 rounded-lg cursor-pointer hover:bg-surface hover:border-content-muted transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Continue with GitHub
      </button>

      <script>
        import { signIn } from 'auth-astro/client'
        document.getElementById('github-signin')?.addEventListener('click', () => {
          const params = new URLSearchParams(window.location.search)
          const redirect = params.get('redirect') ?? '/courses'
          signIn('github', { callbackUrl: redirect })
        })
      </script>

      <!-- What you get -->
      <div class="mt-10 text-left space-y-3">
        <p class="text-content-muted text-xs font-medium uppercase tracking-wide">What you get</p>
        <div class="flex items-start gap-2.5 text-sm text-content-secondary">
          <span class="text-success mt-0.5 shrink-0">&#10003;</span>
          Progress synced across all your devices
        </div>
        <div class="flex items-start gap-2.5 text-sm text-content-secondary">
          <span class="text-success mt-0.5 shrink-0">&#10003;</span>
          Your own GitHub repo for each course
        </div>
        <div class="flex items-start gap-2.5 text-sm text-content-secondary">
          <span class="text-success mt-0.5 shrink-0">&#10003;</span>
          Automated progress tracking via GitHub Actions
        </div>
      </div>

      <p class="text-content-muted text-xs mt-8">
        No account needed to browse courses. <a href="/courses" class="text-accent hover:text-accent-dim no-underline">Continue without signing in</a>
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>
