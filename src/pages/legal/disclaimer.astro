---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/shared/components/Navbar.astro'
import fs from 'node:fs'
import path from 'node:path'
import matter from 'gray-matter'
import { marked } from 'marked'

const filePath = path.join(process.cwd(), 'content/legal/disclaimer.mdx')
const raw = matter(fs.readFileSync(filePath, 'utf8'))
const content = marked.parse(raw.content) as string
---

<BaseLayout title="Disclaimer — Dot Code School">
  <Navbar />
  <main class="max-w-3xl mx-auto px-4 py-8 prose prose-invert text-content-secondary prose-headings:font-heading prose-headings:text-content-primary">
    <Fragment set:html={content} />
  </main>
</BaseLayout>
