---
export const prerender = true

import LessonLayout from '@/features/courses/components/LessonLayout'
import LessonNav from '@/features/courses/components/LessonNav.astro'
import SidebarNav, { MobileSidebarToggle } from '@/features/courses/components/SidebarNav'
import { getChangedFiles } from '@/features/courses/lib/files'
import { getCourse, getCourses, getLesson } from '@/features/courses/lib/loader'
import { getNavigation } from '@/features/courses/lib/navigation'
import { asCourseSlug, asLessonSlug,asSectionSlug } from '@/features/courses/types'
import { LessonCheckbox } from '@/features/progress/components/LessonCheckbox'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/shared/components/Navbar.astro'

export function getStaticPaths() {
  const courses = getCourses()
  const paths = []
  for (const summary of courses) {
    const course = getCourse(summary.slug)
    if (!course) continue
    for (const section of course.sections) {
      for (const lessonSummary of section.lessons) {
        paths.push({
          params: {
            courseSlug: course.slug,
            sectionSlug: section.slug,
            lessonSlug: lessonSummary.slug,
          },
        })
      }
    }
  }
  return paths
}

const { courseSlug, sectionSlug, lessonSlug } = Astro.params
const course = getCourse(asCourseSlug(courseSlug!))
const lesson = await getLesson(asCourseSlug(courseSlug!), asSectionSlug(sectionSlug!), asLessonSlug(lessonSlug!))

if (!course || !lesson) return Astro.redirect('/404')

const nav = getNavigation(asCourseSlug(courseSlug!), asSectionSlug(sectionSlug!), asLessonSlug(lessonSlug!))
const { editorFiles, diffFiles, solutionFiles, readOnly } = getChangedFiles(
  asCourseSlug(courseSlug!), asSectionSlug(sectionSlug!), asLessonSlug(lessonSlug!)
)
const pageUrl = `https://dotcodeschool.com/courses/${courseSlug}/${sectionSlug}/${lessonSlug}`
const githubEditUrl = `https://github.com/dotcodeschool/frontend/edit/master/content/courses/${courseSlug}/sections/${sectionSlug}/lessons/${lessonSlug}/${lessonSlug}.mdx`
---

<BaseLayout title={`${lesson.title} — ${course.title}`}>
  <Navbar showLinks={false} />

  <!-- Mobile header bar with hamburger + lesson title -->
  <div class="md:hidden flex items-center px-3 py-2 border-b border-border bg-surface">
    <MobileSidebarToggle client:load />
    <span class="text-xs text-content-muted truncate">{lesson.title}</span>
  </div>

  <!-- Mobile drawer sidebar -->
  <div class="md:hidden">
    <SidebarNav
      course={course}
      currentSection={asSectionSlug(sectionSlug!)}
      currentLesson={asLessonSlug(lessonSlug!)}
      mobile={true}
      client:load
    />
  </div>

  <div class="flex h-[calc(100vh-88px)] md:h-[calc(100vh-48px)]">
    <!-- Desktop sidebar -->
    <aside class="w-[260px] min-w-[260px] border-r border-border hidden md:block">
      <SidebarNav
        course={course}
        currentSection={asSectionSlug(sectionSlug!)}
        currentLesson={asLessonSlug(lessonSlug!)}
        client:load
      />
    </aside>
    <div class="flex-1 flex flex-col overflow-hidden">
      <!-- Static skeleton visible immediately while React loads -->
      <div id="lesson-skeleton" class="flex-1 overflow-y-auto p-8">
        <h1 class="font-heading text-2xl font-bold mb-2">{lesson.title}</h1>
        {lesson.lastUpdated && (
          <p class="text-content-muted text-xs mb-6">Last updated {lesson.lastUpdated}</p>
        )}
        <div class="space-y-3 animate-pulse">
          <div class="h-4 bg-elevated rounded w-full"></div>
          <div class="h-4 bg-elevated rounded w-5/6"></div>
          <div class="h-4 bg-elevated rounded w-4/6"></div>
          <div class="h-4 bg-elevated rounded w-full"></div>
          <div class="h-4 bg-elevated rounded w-3/6"></div>
        </div>
      </div>
      <!-- React island replaces skeleton once loaded -->
      <div id="lesson-content" class="hidden flex-1 min-h-0 overflow-hidden">
        <LessonLayout
          code={lesson.code}
          title={lesson.title}
          lastUpdated={lesson.lastUpdated}
          editorFiles={editorFiles}
          diffFiles={diffFiles}
          solutionFiles={solutionFiles}
          readOnly={readOnly}
          pageUrl={pageUrl}
          githubEditUrl={githubEditUrl}
          client:only="react"
        />
      </div>
      <script is:inline>
        // Show React content and hide skeleton once the island hydrates
        const observer = new MutationObserver(() => {
          const content = document.getElementById('lesson-content')
          if (content && content.children.length > 0 && content.children[0].children.length > 0) {
            content.classList.remove('hidden')
            document.getElementById('lesson-skeleton')?.remove()
            observer.disconnect()
          }
        })
        const content = document.getElementById('lesson-content')
        if (content) observer.observe(content, { childList: true, subtree: true })
      </script>
      <div class="flex items-center justify-end px-5 py-2 border-t border-border bg-surface">
        <LessonCheckbox courseSlug={courseSlug!} lessonSlug={lessonSlug!} client:load />
      </div>
      <LessonNav nav={nav} />
    </div>
  </div>
</BaseLayout>
