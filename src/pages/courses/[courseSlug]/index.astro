---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/shared/components/Navbar.astro'
import CourseOverview from '@/features/courses/components/CourseOverview.astro'
import { getCourse, getCourses } from '@/features/courses/lib/loader'
import { asCourseSlug } from '@/features/courses/types'

export function getStaticPaths() {
  const courses = getCourses()
  return courses.map(c => ({ params: { courseSlug: c.slug } }))
}

const { courseSlug } = Astro.params
const course = getCourse(asCourseSlug(courseSlug!))

if (!course) return Astro.redirect('/404')
---

<BaseLayout title={`${course.title} — Dot Code School`}>
  <Navbar />
  <main class="max-w-3xl mx-auto px-4 py-8">
    <a href="/courses" class="text-accent text-4xl mb-4 block">←</a>
    <CourseOverview course={course} />
  </main>
</BaseLayout>
