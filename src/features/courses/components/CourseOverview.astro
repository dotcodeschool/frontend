---
import type { Course } from '../types'
import { FaPuzzlePiece, FaClock, FaBookOpen, FaClipboardList, FaGraduationCap } from 'react-icons/fa'
import CourseAccordion from './CourseAccordion'
import TruncatedContent from './TruncatedContent'
import PrerequisitesPopover from './PrerequisitesPopover'

interface Props {
  course: Course
  code?: string
}

const { course, code } = Astro.props

const totalLessons = course.sections.reduce((sum, s) => sum + s.lessons.length, 0)
const firstLesson = course.sections[0]?.lessons[0]
const startHref = firstLesson
  ? `/courses/${course.slug}/${course.sections[0].slug}/${firstLesson.slug}`
  : null
const hasPrereqs = course.prerequisites && course.prerequisites.length > 0
---

<div>
  <!-- Back arrow -->
  <a href="/courses" class="text-accent text-2xl mb-4 block no-underline hover:text-accent-dim transition-colors">←</a>

  <!-- Header -->
  <h1 class="font-heading text-3xl font-bold mb-3">{course.title}</h1>

  {course.authorUrl ? (
    <p class="text-content-muted text-sm mb-2">
      Written by <a href={course.authorUrl} class="text-accent no-underline hover:underline" target="_blank" rel="noopener">{course.author}</a>
    </p>
  ) : (
    <p class="text-content-muted text-sm mb-2">Written by {course.author}</p>
  )}

  <p class="text-content-secondary mb-3 leading-relaxed">{course.description}</p>

  {course.lastUpdated && (
    <p class="text-content-faint text-xs mb-6">Last updated: {course.lastUpdated}</p>
  )}

  <!-- Start Course button -->
  {startHref && (
    <a href={startHref}
       class="inline-block bg-accent text-base font-medium px-10 py-3 rounded-md no-underline mb-8"
       style="color: var(--bg-base);">
      Start Course
    </a>
  )}

  <!-- Stats Card -->
  <div class="border border-border rounded-lg bg-surface p-6 mb-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="flex items-center gap-3">
        <div class="text-accent text-lg"><FaPuzzlePiece /></div>
        <div>
          <p class="text-content-faint text-xs">Skill Level</p>
          <p class="text-content-primary font-semibold text-sm">{course.level}</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="text-accent text-lg"><FaClock /></div>
        <div>
          <p class="text-content-faint text-xs">Time to Complete</p>
          <p class="text-content-primary font-semibold text-sm">{course.estimatedTime ? `${course.estimatedTime} hours` : 'Self-paced'}</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="text-accent text-lg"><FaBookOpen /></div>
        <div>
          <p class="text-content-faint text-xs">Course Content</p>
          <p class="text-content-primary font-semibold text-sm">{course.sections.length} sections</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="text-accent text-lg"><FaClipboardList /></div>
        <div>
          <p class="text-content-faint text-xs">
            Prerequisites
            {hasPrereqs && (
              <PrerequisitesPopover prerequisites={course.prerequisites!} client:load />
            )}
          </p>
          <p class="text-content-primary font-semibold text-sm">
            {hasPrereqs ? `${course.prerequisites!.length} ${course.prerequisites!.length === 1 ? 'course' : 'courses'}` : 'None'}
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Two-column: About + Sidebar cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
    <!-- Left column: About This Course (2/3) -->
    <div class="md:col-span-2">
      <h2 class="font-heading text-xl font-semibold text-content-primary mb-4">About This Course</h2>
      {code ? (
        <TruncatedContent code={code} maxHeight={200} client:load />
      ) : (
        <p class="text-content-secondary leading-relaxed">{course.description}</p>
      )}
    </div>

    <!-- Right column: Sidebar cards (1/3) -->
    <div class="space-y-4">
      <!-- What You'll Learn -->
      {course.whatYoullLearn && course.whatYoullLearn.length > 0 && (
        <div class="border border-border rounded-lg bg-surface p-5">
          <h3 class="font-heading text-base font-semibold text-content-primary mb-3">What You'll Learn</h3>
          <ul class="space-y-2.5">
            {course.whatYoullLearn.map((item) => (
              <li class="flex items-start gap-2 text-sm text-content-secondary">
                <span class="text-success mt-0.5 shrink-0">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Prerequisites -->
      {hasPrereqs && (
        <div class="border border-border rounded-lg bg-surface p-5">
          <h3 class="font-heading text-base font-semibold text-content-primary mb-3 flex items-center gap-2">
            <span class="text-accent"><FaGraduationCap /></span>
            Prerequisites
          </h3>
          <ul class="space-y-2.5">
            {course.prerequisites!.map((prereq) => (
              <li class="flex items-start gap-2 text-sm text-content-secondary">
                <span class="text-success mt-0.5 shrink-0">✓</span>
                {prereq}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </div>

  <!-- Divider -->
  <hr class="border-border mb-10" />

  <!-- Course Content -->
  <div class="mb-8">
    <h2 class="font-heading text-xl font-semibold text-content-primary mb-1">Course Content</h2>
    <p class="text-content-muted text-sm mb-6">
      {course.sections.length} sections · {totalLessons} lessons
    </p>

    <CourseAccordion sections={course.sections} courseSlug={course.slug} client:load />
  </div>
</div>
