---
import type { Course } from '../types'

interface Props {
  course: Course
}

const { course } = Astro.props
---

<div>
  <h1 class="font-heading text-3xl font-bold mb-2">{course.title}</h1>
  <p class="text-content-muted text-sm mb-4">{course.level} · {course.language} · by {course.author}</p>
  <p class="text-content-secondary mb-8 leading-relaxed">{course.description}</p>

  {course.estimatedTime && (
    <p class="text-content-muted text-sm mb-8">Estimated time: {course.estimatedTime} hours</p>
  )}

  <div class="space-y-6">
    {course.sections.map((section, sIndex) => (
      <div>
        <h2 class="font-heading text-lg font-semibold text-content-primary mb-3">{section.title}</h2>
        {section.description && (
          <p class="text-content-muted text-sm mb-2">{section.description}</p>
        )}
        <ul class="space-y-1 pl-4">
          {section.lessons.map((lesson) => {
            const href = `/courses/${course.slug}/${section.slug}/${lesson.slug}`
            return (
              <li>
                <a href={href}
                   class="flex items-center gap-2 py-1.5 px-3 rounded text-sm text-content-muted hover:text-content-secondary hover:bg-elevated transition-colors no-underline">
                  <span class="w-1.5 h-1.5 rounded-full bg-content-faint shrink-0" />
                  {lesson.title}
                </a>
              </li>
            )
          })}
        </ul>
      </div>
    ))}
  </div>

  {course.sections[0]?.lessons[0] && (
    <a href={`/courses/${course.slug}/${course.sections[0].slug}/${course.sections[0].lessons[0].slug}`}
       class="inline-block mt-8 bg-accent text-sm font-medium px-8 py-3 rounded-md no-underline"
       style="color: var(--bg-base);">
      Start Course
    </a>
  )}
</div>
