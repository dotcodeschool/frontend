---
import { AuthButton } from '@/features/auth/components/AuthButton'
import { SyncStatus } from '@/features/progress/components/SyncStatus'

import { ThemeToggle } from './ThemeToggle'

interface Props {
  showLinks?: boolean
}

const { showLinks = true } = Astro.props
---

<nav class="flex items-center justify-between px-5 h-12 border-b border-border bg-surface">
  <!-- Logo -->
  <a href="/" class="flex items-center gap-1.5 no-underline group">
    <span class="font-mono text-accent font-bold text-sm">&lt;/&gt;</span>
    <span class="font-heading text-content-primary text-base font-semibold group-hover:text-accent transition-colors">dotcodeschool</span>
  </a>

  <!-- Nav links (center, hidden on lesson pages) -->
  {showLinks && (
    <div class="hidden md:flex items-center gap-6 text-sm font-body">
      <a href="/courses" class="text-content-muted hover:text-content-secondary transition-colors no-underline">Courses</a>
      <a href="/articles" class="text-content-muted hover:text-content-secondary transition-colors no-underline">Articles</a>
    </div>
  )}

  <!-- Right side -->
  <div class="flex items-center gap-2">
    <ThemeToggle client:load />
    <SyncStatus client:load />
    <div class="hidden md:block">
      <AuthButton client:load />
    </div>

    <!-- Mobile menu button -->
    {showLinks && (
      <button
        id="mobile-menu-btn"
        class="md:hidden p-1.5 text-content-muted hover:text-content-secondary transition-colors"
        aria-label="Open menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    )}
  </div>
</nav>

<!-- Mobile menu drawer -->
{showLinks && (
  <div id="mobile-menu" class="hidden md:hidden border-b border-border bg-surface">
    <div class="flex flex-col px-5 py-3 gap-3">
      <a href="/courses" class="text-content-muted text-sm hover:text-content-secondary transition-colors no-underline">Courses</a>
      <a href="/articles" class="text-content-muted text-sm hover:text-content-secondary transition-colors no-underline">Articles</a>
      <AuthButton client:load />
    </div>
  </div>

  <script is:inline>
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden')
    })
  </script>
)}
